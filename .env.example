# GenLayer Reputation Oracle - Environment Variables
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════════
# NETWORK CONFIGURATION (Optional - defaults are provided)
# ═══════════════════════════════════════════════════════════════════════════════

# GenLayer Testnet RPC URL
VITE_GENLAYER_RPC_URL=https://rpc.testnet-chain.genlayer.com

# Chain ID
VITE_CHAIN_ID=4221

# Explorer URL
VITE_EXPLORER_URL=https://explorer.testnet-chain.genlayer.com

# ═══════════════════════════════════════════════════════════════════════════════
# CONTRACT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Deployed contract address (set after deployment)
VITE_CONTRACT_ADDRESS=

# ═══════════════════════════════════════════════════════════════════════════════
# IMPORTANT NOTES
# ═══════════════════════════════════════════════════════════════════════════════

# 1. Get testnet GEN tokens from: https://testnet-faucet.genlayer.foundation/
# 2. Deploy the contract via GenLayer Studio: https://studio.genlayer.com
# 3. NEVER commit private keys to git!
